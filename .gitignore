# AndroidProject/app/src/main/assets/asset_manifest.txt

# Android built libraries
AndroidProject/app/src/main/jniLibs/arm64-v8a/libEngine.so
AndroidProject/app/src/main/jniLibs/arm64-v8a/libgam300android.so

# Gradle
AndroidProject/.gradle/
AndroidProject/build/
AndroidProject/*/build/
AndroidProject/gradle-wrapper.jar

# Local configuration
AndroidProject/local.properties

