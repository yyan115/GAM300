                                            "type": "std::string",
                                            "data": "../../Resources/Cutscenes/Kusane_OpeningCutscene/1.PNG"
                                        },
                                        {
                                            "type": "std::string",
                                            "data": "High above the silent mountains, stood a temple untouched by war. A sanctuary of sky and stone... Home."
                                        },
                                        {
                                            "type": "float",
                                            "data": 20
                                        },
                                        {
                                            "type": "bool",
                                            "data": false
                                        },
                                        {
