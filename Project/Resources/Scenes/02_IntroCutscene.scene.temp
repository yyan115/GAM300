                                    "data": [
                                        {
                                            "type": "std::string",
                                            "data": "../../Resources/Cutscenes/Kusane_OpeningCutscene/4.PNG"
                                        },
                                        {
                                            "type": "std::string",
                                            "data": "In a single breath... home became memory.\nShe felt it before she saw it. The silence. The absence."
                                        },
                                        {
                                            "type": "float",
                                            "data": 20
                                        },
                                        {
                                            "type": "bool",
