                                    "type": "CutsceneBoard",
                                    "data": [
                                        {
                                            "type": "std::string",
                                            "data": "../../Resources/Cutscenes/Kusane_OpeningCutscene/2.PNG"
                                        },
                                        {
                                            "type": "std::string",
                                            "data": "And from that sanctuary, Kusane soared.\nShe did not know... how fragile peace truly was."
                                        },
                                        {
                                            "type": "float",
                                            "data": 20
                                        },
                                        {
                                            "type": "bool",
                                            "data": false
                                        },
                                        {
                                            "type": "float",
