                                            "type": "std::string",
                                            "data": "../../Resources/Cutscenes/Kusane_OpeningCutscene/3.PNG"
                                        },
                                        {
                                            "type": "std::string",
                                            "data": "Shadows gathered. The Karasu descended like falling night, destroying everything in sight."
                                        },
                                        {
                                            "type": "float",
                                            "data": 20
                                        },
                                        {
                                            "type": "bool",
                                            "data": false
                                        },
