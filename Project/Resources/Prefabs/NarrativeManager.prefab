                "DialogueComponent": {
                    "type": "DialogueComponent",
                    "data": [
                        {
                            "type": "std::string",
                            "data": "Intro"
                        },
                        {
                            "type": "std::string",
                            "data": "006f7aa42981fc28-0004792d40236cb7"
                        },
                        {
                            "type": "int",
                            "data": 1
                        },
                        {
                            "type": "float",
                            "data": 0.5
                        },
                        {
                            "type": "bool",
                            "data": true
                        },
                        {
                            "type": "float",
                            "data": 30
                        },
                        {
                            "type": "std::vector<DialogueEntry>",
                            "data": [
                                {
                                    "type": "DialogueEntry",
                                    "data": [
                                        {
                                            "type": "std::string",
                                            "data": "The Karasu took everything."
                                        },
                                        {
                                            "type": "int",
                                            "data": 2
                                        },
                                        {
                                            "type": "float",
                                            "data": 3
                                        },
                                        {
                                            "type": "std::string",
                                            "data": "0071d71f54f0415b-0004793df00687e1"
                                        },
                                        {
                                            "type": "std::string",
                                            "data": ""
                                        }
                                    ]
                                },
                                {
                                    "type": "DialogueEntry",
                                    "data": [
                                        {
                                            "type": "std::string",
                                            "data": "An old temple weapon... Good."
                                        },
                                        {
                                            "type": "int",
                                            "data": 0
                                        },
                                        {
                                            "type": "float",
                                            "data": 3
                                        },
                                        {
                                            "type": "std::string",
                                            "data": "0051f0b56373c6f9-0004737358001e5d"
                                        },
                                        {
                                            "type": "std::string",
                                            "data": ""
                                        }
                                    ]
                                },
                                {
                                    "type": "DialogueEntry",
                                    "data": [
                                        {
                                            "type": "std::string",
                                            "data": "If I cannot strike them in the air, I will drag them down."
                                        },
                                        {
                                            "type": "int",
                                            "data": 2
                                        },
                                        {
                                            "type": "float",
                                            "data": 3
                                        },
                                        {
                                            "type": "std::string",
                                            "data": "0071d71f258f8d69-0004793df00687e3"
                                        },
                                        {
                                            "type": "std::string",
                                            "data": ""
                                        }
                                    ]
                                },
                                {
                                    "type": "DialogueEntry",
                                    "data": [
                                        {
                                            "type": "std::string",
                                            "data": "Now the Karasu will pay."
                                        },
                                        {
                                            "type": "int",
                                            "data": 0
                                        },
                                        {
                                            "type": "float",
                                            "data": 3
                                        },
                                        {
                                            "type": "std::string",
                                            "data": "0071d71f34acfb9b-0004793df00687e5"
                                        },
                                        {
                                            "type": "std::string",
                                            "data": ""
                                        }
                                    ]
                                },
                                {
                                    "type": "DialogueEntry",
                                    "data": [
                                        {
                                            "type": "std::string",
                                            "data": "Perfect timing. Let's see what this weapon can do."
                                        },
                                        {
                                            "type": "int",
                                            "data": 2
                                        },
                                        {
                                            "type": "float",
                                            "data": 3
                                        },
                                        {
                                            "type": "std::string",
                                            "data": "005edbd928ce923f-00047d1e44000d71"
                                        },
                                        {
                                            "type": "std::string",
                                            "data": ""
                                        }
                                    ]
                                },
                                {
                                    "type": "DialogueEntry",
                                    "data": [
                                        {
                                            "type": "std::string",
                                            "data": "Ahh... the survivor."
                                        },
                                        {
                                            "type": "int",
                                            "data": 0
                                        },
                                        {
                                            "type": "float",
                                            "data": 3
                                        },
                                        {
                                            "type": "std::string",
                                            "data": "005edbd928ce923f-00047d1e44000d71"
                                        },
                                        {
                                            "type": "std::string",
                                            "data": ""
                                        }
                                    ]
                                },
                                {
                                    "type": "DialogueEntry",
                                    "data": [
                                        {
                                            "type": "std::string",
                                            "data": "I wondered if one of you would crawl back."
                                        },
                                        {
                                            "type": "int",
                                            "data": 0
                                        },
                                        {
                                            "type": "float",
                                            "data": 3
                                        },
                                        {
                                            "type": "std::string",
                                            "data": "0071d71f34acfb9b-0004793df00687e5"
                                        },
                                        {
                                            "type": "std::string",
                                            "data": ""
                                        }
                                    ]
                                },
                                {
                                    "type": "DialogueEntry",
                                    "data": [
                                        {
                                            "type": "std::string",
                                            "data": "Do you like my new wings?"
                                        },
                                        {
                                            "type": "int",
                                            "data": 0
                                        },
                                        {
                                            "type": "float",
                                            "data": 3
                                        },
                                        {
                                            "type": "std::string",
                                            "data": ""
                                        },
                                        {
                                            "type": "std::string",
                                            "data": ""
                                        }
                                    ]
                                },
                                {
                                    "type": "DialogueEntry",
                                    "data": [
                                        {
                                            "type": "std::string",
                                            "data": "Those feathers belonged to us, our warriors."
                                        },
                                        {
                                            "type": "int",
                                            "data": 0
                                        },
                                        {
                                            "type": "float",
                                            "data": 3
                                        },
                                        {
                                            "type": "std::string",
                                            "data": ""
                                        },
                                        {
                                            "type": "std::string",
                                            "data": ""
                                        }
                                    ]
                                },
                                {
                                    "type": "DialogueEntry",
                                    "data": [
                                        {
                                            "type": "std::string",
                                            "data": "Warriors? You guarded relics and prayed to ghosts."
                                        },
                                        {
                                            "type": "int",
                                            "data": 0
                                        },
                                        {
                                            "type": "float",
                                            "data": 5
                                        },
                                        {
                                            "type": "std::string",
                                            "data": ""
                                        },
                                        {
                                            "type": "std::string",
                                            "data": ""
                                        }
                                    ]
                                },
                                {
                                    "type": "DialogueEntry",
                                    "data": [
                                        {
                                            "type": "std::string",
                                            "data": "We take what we need to survive."
                                        },
                                        {
                                            "type": "int",
                                            "data": 0
                                        },
                                        {
                                            "type": "float",
                                            "data": 3
                                        },
                                        {
                                            "type": "std::string",
                                            "data": ""
                                        },
                                        {
                                            "type": "std::string",
                                            "data": ""
                                        }
                                    ]
                                },
                                {
                                    "type": "DialogueEntry",
                                    "data": [
                                        {
                                            "type": "std::string",
                                            "data": "Tonight, this temple belongs to the Karasu."
                                        },
                                        {
                                            "type": "int",
                                            "data": 0
                                        },
                                        {
                                            "type": "float",
                                            "data": 3
                                        },
                                        {
                                            "type": "std::string",
                                            "data": ""
                                        },
                                        {
                                            "type": "std::string",
                                            "data": ""
                                        }
                                    ]
                                },
                                {
                                    "type": "DialogueEntry",
                                    "data": [
                                        {
                                            "type": "std::string",
                                            "data": "...No. Tonight... It ends."
                                        },
                                        {
                                            "type": "int",
                                            "data": 0
                                        },
                                        {
                                            "type": "float",
                                            "data": 3
                                        },
                                        {
                                            "type": "std::string",
                                            "data": ""
                                        },
                                        {
                                            "type": "std::string",
                                            "data": ""
                                        }
                                    ]
                                }
                            ]
                        },
                        {
                            "type": "bool",
                            "data": true
                        }
                    ]
                }
            }
        },
